{
  "name": "oauth-mcp-proxy",
  "version": "2.1.1",
  "description": "OAuth MCP Proxy - Bypass buggy OAuth implementations in MCP clients by handling authentication locally",
  "main": "oauth-helper.js",
  "type": "module",
  "bin": {
    "oauth-helper": "./oauth-helper.js",
    "mcp-proxy": "./mcp-proxy.js"
  },
  "scripts": {
    "auth": "node oauth-helper.js",
    "proxy": "node mcp-proxy.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "prepare": "husky install",
    "commitlint": "commitlint --edit $1"
  },
  "keywords": [
    "oauth",
    "mcp",
    "model-context-protocol",
    "authentication",
    "proxy"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/oauth-mcp-proxy"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "js-yaml": "^4.1.0",
    "node-fetch": "^3.3.2",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "semantic-release": "^25.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": ["@commitlint/config-conventional"]
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "*.js",
      "!node_modules/**",
      "!tests/**"
    ]
  }
}